# Google Gemini AI API Key (Required)
# Get this from: https://aistudio.google.com/apikey
# USERS: Replace with your actual API key
GOOGLE_API_KEY=your_google_ai_api_key_here

# Google Calendar ID (Optional)
GOOGLE_CALENDAR_ID=primary

# Note: Without GOOGLE_SERVICE_ACCOUNT_JSON, the system will work with mock data
# This allows the agent to demonstrate functionality even without real calendar access